generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AILogStream {
  id          String    @id @default(uuid())
  botConfigId String
  step        AIStep
  content     String
  status      LogStatus @default(PENDING)
  timestamp   DateTime  @default(now())
  BotConfig   BotConfig @relation(fields: [botConfigId], references: [id], onDelete: Cascade)
}

model ActiveTranche {
  id                  String    @id @default(uuid())
  botConfigId         String
  symbol              String
  side                String
  status              TrancheStatus @default(OPEN)
  trancheGroupId      String
  entryPrice          Float
  exitPrice           Float?
  pnlUsdt             Float?
  originalAmount      Float
  remainingAmount     Float
  isCapitalExtracted  Boolean   @default(false)
  isPaperTrade        Boolean   @default(false)
  takeProfitPrice     Float?
  stopLossPrice       Float?
  trailingStopPrice   Float?
  highestPriceReached Float     @default(0)
  openedAt            DateTime  @default(now())
  closedAt            DateTime?
  BotConfig           BotConfig @relation(fields: [botConfigId], references: [id], onDelete: Cascade)
}

enum TrancheStatus {
  OPEN
  CLOSED
  CANCELLED
}

model BotConfig {
  id                              String          @id @default(uuid())
  userId                          String
  allocatedPortfolioUsdt          Float           @default(0)
  paperBalanceUsdt                Float           @default(100000) // Default paper capital
  targetProfitUsdt                Float           @default(0)
  minSplits                       Int             @default(5)
  maxSplits                       Int             @default(10)
  capitalExtractionTriggerPercent Float           @default(5.0)
  autoBreakevenTriggerPercent     Float           @default(2.5)
  isActive                        Boolean         @default(true)
  isPaperTrading                  Boolean         @default(true) // Default to paper for safety
  aiDirectives                    String?         @default("เน้นความปลอดภัยและกำไรที่สม่ำเสมอ")
  AILogStream                     AILogStream[]
  ActiveTranche                   ActiveTranche[]
  User                            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SecurityAbuseLog {
  id          String    @id
  userId      String?
  alertType   AbuseType
  description String
  ipAddress   String?
  resolved    Boolean   @default(false)
  timestamp   DateTime  @default(now())
  User        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                 String             @id
  email              String             @unique
  passwordHash       String?
  authProvider       AuthProvider       @default(CREDENTIALS)
  role               Role               @default(USER)
  status             Status             @default(ACTIVE)
  bitgetApiKey       String?
  bitgetApiSecret    String?
  bitgetPassphrase   String?
  bitgetDemoApiKey                String?
  bitgetDemoApiSecret             String?
  bitgetDemoPassphrase            String?
  aiApiKey           String?
  aiProvider         String?            @default("OPENAI")
  aiModel            String?            @default("gpt-4o")
  hasAcceptedTerms   Boolean            @default(false)
  hasAcceptedCookies Boolean            @default(false)
  consentDate        DateTime?
  lastActive         DateTime           @default(now())
  createdAt          DateTime           @default(now())
  updatedAt          DateTime
  BotConfig          BotConfig[]
  SecurityAbuseLog   SecurityAbuseLog[]
}

enum AIStep {
  TRIGGER
  PLAN
  IMPLEMENT
  TASK_CHECK
  FEEDBACK_RETRY
}

enum AbuseType {
  RATE_LIMIT
  SUSPICIOUS_IP
  CCXT_ERROR_SPAM
  BRUTE_FORCE
}

enum AuthProvider {
  CREDENTIALS
  GOOGLE
}

enum LogStatus {
  PENDING
  SUCCESS
  FAILED
}

enum Role {
  USER
  ADMIN
}

enum Status {
  ACTIVE
  SUSPENDED
  BANNED
}
